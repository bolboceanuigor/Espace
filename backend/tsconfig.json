{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/main.ts",
    "src/app.module.ts",
    "src/app.controller.ts",
    "src/prisma/**/*.ts",
    "src/organizations/**/*.ts",
    "src/apartments/**/*.ts",
    "src/residents/**/*.ts",
    "src/meters/**/*.ts",
    "src/billing-read/**/*.ts",
    "src/community-read/**/*.ts",
    "src/resident-demo/**/*.ts",
    "src/common/filters/**/*.ts",
    "src/common/interceptors/**/*.ts",
    "src/auth/decorators/public.decorator.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "prisma/seed.ts",
    "prisma/seed.demo.ts",
    "prisma/seed.production-base.ts",
    "src/admin/**",
    "src/activity/**",
    "src/team/**",
    "src/feedback/**",
    "src/invitations/**",
    "src/superadmin/**",
    "src/rbac/**",
    "src/reports/**",
    "src/maintenance/**",
    "src/reconciliation/**",
    "src/reminders/**",
    "src/onboarding/**",
    "src/leads/**",
    "src/help/**",
    "src/files/**",
    "src/privacy/**",
    "src/release-notes/**",
    "src/demo-requests/**",
    "src/roadmap/**",
    "src/sales/**",
    "src/scheduler/**",
    "src/subscription/**",
    "src/system-monitoring/**",
    "src/votes/**",
    "src/reservations/**",
    "src/properties/**",
    "src/clients/**",
    "src/calendar/**",
    "src/cleanings/**",
    "src/channels/**",
    "src/manager/**",
    "src/dashboard/**",
    "src/exports/**"
  ]
}
