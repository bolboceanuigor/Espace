{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "prisma/seed.ts",
    "prisma/seed.production-base.ts",
    "src/admin/**",
    "src/activity/**",
    "src/team/**",
    "src/feedback/**",
    "src/invitations/**",
    "src/superadmin/**",
    "src/rbac/**",
    "src/reports/**",
    "src/maintenance/**",
    "src/reconciliation/**",
    "src/reminders/**",
    "src/onboarding/**",
    "src/leads/**",
    "src/help/**",
    "src/files/**",
    "src/privacy/**",
    "src/release-notes/**",
    "src/demo-requests/**",
    "src/roadmap/**",
    "src/sales/**",
    "src/scheduler/**",
    "src/subscription/**",
    "src/system-monitoring/**",
    "src/votes/**",
    "src/reservations/**",
    "src/properties/**",
    "src/clients/**",
    "src/calendar/**",
    "src/cleanings/**",
    "src/channels/**",
    "src/manager/**",
    "src/dashboard/**",
    "src/exports/**"
  ]
}
