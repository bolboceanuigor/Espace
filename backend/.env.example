# Backend runtime.
APP_NAME="Espace SaaS"
APP_ENV="production"
APP_DEBUG="false"
NODE_ENV="production"
PORT=4000

# PostgreSQL runtime.
# Example for Docker Compose / VPS:
DATABASE_URL="postgresql://espace:replace_me@postgres:5432/espace_db?schema=public"
DIRECT_URL="postgresql://espace:replace_me@postgres:5432/espace_db?schema=public"
# Example for Supabase or managed PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Required auth settings. Use a long random JWT_SECRET in staging/production.
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Public URLs.
FRONTEND_URL="https://www.espace.md"
APP_URL="https://www.espace.md"
API_URL="https://www.espace.md/api"

# Comma-separated allowed browser origins. Do not use "*" in production.
CORS_ORIGIN="https://www.espace.md,https://espace.md"
CORS_ALLOW_VERCEL_PREVIEWS="false"
COOKIE_SECURE="true"
COOKIE_SAMESITE="lax"
COOKIE_DOMAIN=".espace.md"
TRUST_PROXY="true"
LOG_HTTP="false"
APP_VERSION="0.1.0-beta"
FILE_STORAGE_PROVIDER="LOCAL"

# Transactional notification delivery. Do not commit real API keys.
# Production should use a real provider and keep dev mode disabled.
NOTIFICATIONS_EXTERNAL_ENABLED="true"
NOTIFICATIONS_DEV_MODE="false"
EMAIL_PROVIDER="RESEND"
EMAIL_FROM_NAME="Espace SaaS"
EMAIL_FROM_ADDRESS="no-reply@espace.md"
EMAIL_REPLY_TO="support@espace.md"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
EMAIL_FROM="Espace SaaS <no-reply@espace.md>"
SUPPORT_EMAIL="support@espace.md"

# Optional SMTP fallback.
MAIL_ENABLED="false"
MAIL_FROM="Espace SaaS <no-reply@espace.md>"
EMAIL_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_PASS=""
SMS_PROVIDER="CONSOLE"
SMS_FROM=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
CUSTOM_SMS_ENDPOINT=""
CUSTOM_SMS_API_KEY=""

# Optional Google auth. Leave disabled for MVP unless configured end to end.
ENABLE_GOOGLE_AUTH="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://www.espace.md/api/auth/google/callback"
ENABLE_DEMO_LOGIN="false"
ALLOW_LEGACY_ADMIN_PERMISSION_FALLBACK="false"
PAYMENTS_EXTERNAL_ENABLED="false"
PAYMENTS_TEST_MODE="true"
PAYMENTS_MANUAL_TEST_WEBHOOK_SECRET=""
BPAY_ENABLED="false"
BPAY_MERCHANT_ID=""
BPAY_API_KEY=""
BPAY_SECRET=""

# Reserved placeholders for future live providers. Keep empty until runtime support is implemented.
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
PAYSTACK_SECRET_KEY=""
PAYSTACK_WEBHOOK_SECRET=""
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_WEBHOOK_SECRET=""
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""

ENABLE_CHANNELS_UI="false"

# Optional local/bootstrap scripts only. Do not use weak values in production.
SUPERADMIN_EMAIL="platform-admin@espace.md"
SUPERADMIN_PASSWORD="change-me-local-bootstrap-only"
PRODUCTION_SUPERADMIN_EMAIL=""
PRODUCTION_SUPERADMIN_PASSWORD=""
PRODUCTION_SUPERADMIN_FIRST_NAME="Platform"
PRODUCTION_SUPERADMIN_LAST_NAME="Admin"
PRODUCTION_SUPERADMIN_PHONE=""
PRODUCTION_SUPERADMIN_ORGANIZATION_ID=""
MANAGER_TEST_EMAIL="manager.test@espace.md"
MANAGER_TEST_PASSWORD="change-me-local-test-only"
SEED="false"
SEED_DEMO="false"
SEED_SUPERADMIN_PASSWORD=""
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
