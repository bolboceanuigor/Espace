# Render production runtime.
NODE_ENV="production"
PORT=10000

# Supabase PostgreSQL.
# DATABASE_URL should use the Supabase Transaction Pooler/PgBouncer URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL should use the Supabase direct PostgreSQL URL for approved Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Required auth settings. Use a long random JWT_SECRET in Render.
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Public production URLs.
FRONTEND_URL="https://espace.md"
APP_URL="https://espace.md"
# Current Render backend URL. Replace with a custom API domain if one is configured.
API_URL="https://espace-ru41.onrender.com"

# Comma-separated allowed browser origins. Do not use "*" in production.
CORS_ORIGIN="https://espace.md,https://www.espace.md"
CORS_ALLOW_VERCEL_PREVIEWS="false"
COOKIE_SECURE="true"
COOKIE_SAMESITE="lax"
COOKIE_DOMAIN=""
TRUST_PROXY="true"
LOG_HTTP="false"
APP_VERSION="0.1.0-beta"

# Optional email delivery. Backend must still run when these are empty.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="Espace <no-reply@espace.md>"
SUPPORT_EMAIL="support@espace.md"

# Optional SMTP fallback.
MAIL_ENABLED="false"
MAIL_FROM="Espace <no-reply@espace.md>"
EMAIL_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Optional Google auth. Leave disabled for MVP unless configured end to end.
ENABLE_GOOGLE_AUTH="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://espace-ru41.onrender.com/api/auth/google/callback"

ENABLE_CHANNELS_UI="false"

# Optional local/bootstrap scripts only. Do not use weak values in production.
SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me-local-bootstrap-only"
MANAGER_TEST_EMAIL="manager.test@example.com"
MANAGER_TEST_PASSWORD="change-me-local-test-only"
SEED="false"
SEED_DEMO="false"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
