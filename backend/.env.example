NODE_ENV="production"
PORT=10000

# Supabase PostgreSQL.
# DATABASE_URL should use the Supabase Transaction Pooler/PgBouncer URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL should use the Supabase direct PostgreSQL URL for Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

FRONTEND_URL="https://espace.md"
CORS_ORIGIN="https://espace.md,https://www.espace.md"
CORS_ALLOW_VERCEL_PREVIEWS="false"
API_URL="https://api.espace.md"
COOKIE_SECURE="true"
COOKIE_SAMESITE="lax"
COOKIE_DOMAIN=""
TRUST_PROXY="true"
LOG_HTTP="false"
APP_VERSION="0.1.0-beta"
APP_URL="https://espace.md"
EMAIL_PROVIDER="resend"
SUPPORT_EMAIL="support@espace.md"
ENABLE_GOOGLE_AUTH="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api.espace.md/api/auth/google/callback"
MAIL_ENABLED="false"
MAIL_FROM="Espace <no-reply@espace.md>"
EMAIL_API_KEY=""
RESEND_API_KEY=""
EMAIL_FROM="Espace <no-reply@espace.md>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
ENABLE_CHANNELS_UI="false"
SUPERADMIN_PASSWORD="SuperAdmin123!"
SUPERADMIN_EMAIL="admin@example.com"
MANAGER_TEST_PASSWORD="Manager123!"
MANAGER_TEST_EMAIL="manager.test@example.com"
SEED="false"
SEED_DEMO="true"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
