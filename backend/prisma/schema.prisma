  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  batch        ImportedPaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedPayment Payment?           @relation(fields: [matchedPaymentId], references: [id], onDelete: SetNull)
  matches      PaymentMatch[]

  @@index([organizationId, status])
  @@index([batchId])
  @@index([invoiceNumber])
  @@index([apartmentNumber])
  @@index([paymentDate])
  @@map("imported_payments")
}

model PaymentMatch {
  id               String            @id @default(uuid())
  organizationId   String
  importedPaymentId String
  invoiceId        String?
  apartmentId      String?
  confidenceScore  Int
  status           PaymentMatchStatus
  reason           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedPayment ImportedPayment @relation(fields: [importedPaymentId], references: [id], onDelete: Cascade)
  invoice        ResidentInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  apartment      Apartment?       @relation(fields: [apartmentId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([importedPaymentId])
  @@index([invoiceId])
  @@index([apartmentId])
  @@map("payment_matches")
}

model ImportMappingTemplate {
  id             String                @id @default(uuid())
  organizationId String
  source         ImportedPaymentSource
  name           String
  mappingJson    Json
  isDefault      Boolean               @default(false)
  createdByUserId String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ImportMappingTemplateCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  batches      ImportedPaymentBatch[]

  @@index([organizationId, source])
  @@index([createdByUserId])
  @@map("import_mapping_templates")
}

model Property {
  id             String   @id @default(uuid())
  name           String
  code           String?
  color          String?  @default("gray")
  groupId        String?
  address        String?
  isActive       Boolean  @default(true)
  basePrice      Float    @default(0)
  cleaningFee    Float    @default(0)
  rooms          Int      @default(1)
  status         String   @default("active")
  numberOfRooms  Int      @default(1)
  cleaningPrice  Float    @default(0)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  ownerId      String
  owner        User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        PropertyGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  reservations Reservation[]
  cleanings    Cleaning[]
  propertyAccesses PropertyAccess[]
  channels      PropertyChannel[]
  syncConflicts SyncConflict[]
  createdBy     User?         @relation("PropertyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?         @relation("PropertyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, groupId])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
  @@map("properties")
}

model PropertyGroup {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  properties   Property[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("property_groups")
}

model Client {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  phone          String
  email          String?
  notes          String?
  isArchived     Boolean  @default(false)
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reservations Reservation[]
  createdBy     User?        @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?        @relation("ClientUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
  @@map("clients")
}

model Reservation {
  id             String   @id @default(uuid())
  propertyId     String
  clientId       String?
  organizationId String
  checkIn        DateTime
  checkOut       DateTime
  totalPrice     Float
  status         ReservationStatus @default(CONFIRMED)
  channel        Channel?
  source         String?
  externalId     String?
  lastSyncAt     DateTime?
  rawPayload     Json?
  cleaningStatus CleaningStatus @default(TODO)
  guestName      String
  phoneNumber    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy     User?    @relation("ReservationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?    @relation("ReservationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  cleaning      Cleaning?

  @@index([propertyId, checkIn, checkOut])
  @@index([organizationId, propertyId, checkIn, checkOut])
  @@index([organizationId, checkIn, checkOut])
  @@index([organizationId, channel, externalId])
  @@index([clientId])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([createdById])
  @@index([updatedById])
  @@map("reservations")
}

model Cleaning {
  id             String        @id @default(uuid())
  organizationId String
  propertyId     String
  reservationId  String?       @unique
  date           DateTime
  status         CleaningStatus @default(TODO)
  assignedToId   String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation  Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("CleaningAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([organizationId, date])
  @@index([organizationId, propertyId])
  @@index([assignedToId])
  @@map("cleanings")
}

model PropertyChannel {
  id                String   @id @default(uuid())
  organizationId    String
  propertyId        String
  channel           Channel
  externalListingId String?
  icsUrl            String?
  isEnabled         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, channel])
  @@index([organizationId, channel])
  @@index([propertyId])
  @@map("property_channels")
}

model SyncConflict {
  id             String   @id @default(uuid())
  organizationId String
  propertyId     String
  channel        Channel
  externalId     String?
  reason         String
  payload        Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId, propertyId, channel])
  @@index([organizationId, createdAt])
  @@map("sync_conflicts")
}

model PropertyAccess {
  id         String   @id @default(uuid())
  organizationId String @default("")
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, propertyId])
  @@index([organizationId, userId])
  @@index([userId])
  @@index([propertyId])
  @@map("property_accesses")
}
