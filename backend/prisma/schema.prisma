model Organization {
  id                   String    @id @default(uuid())
  name                 String
  legalName            String?
  fiscalCode           String?
  address              String?
  phone                String?
  email                String?
  website              String?
  bankName             String?
  bankAccountIban      String?
  bankSwift            String?
  paymentInstructions  String?
  treasurerName        String?
  administratorName    String?
  city                 String?
  country              String    @default("MD")
  logoUrl              String?
  primaryColor         String?
  invoicePrefix        String?
  receiptPrefix        String?
  currency             BillingCurrency @default(MDL)
  defaultCurrency      BillingCurrency @default(MDL)
  status               OrganizationStatus @default(ACTIVE)
  subscriptionStatus   String    @default("TRIAL")
