model Organization {
  id                   String    @id @default(uuid())
  name                 String
  legalName            String?
  fiscalCode           String?
  address              String?
  phone                String?
  email                String?
  website              String?
  bankName             String?
  bankAccountIban      String?
  bankSwift            String?
  paymentInstructions  String?
  treasurerName        String?
  administratorName    String?
  logoUrl              String?
  primaryColor         String?
  invoicePrefix        String?
  receiptPrefix        String?
  defaultCurrency      BillingCurrency @default(MDL)
  status               String    @default("ACTIVE")
  subscriptionStatus   String    @default("TRIAL")
  subscriptionPlan     String    @default("FREE")
  ownerAdminId         String?
  onboardingCompleted  Boolean   @default(false)
  onboardingStatus     OnboardingStatus @default(NOT_STARTED)
  onboardingStep       String?
  onboardingCompletedAt DateTime?
  betaAccessEnabled    Boolean   @default(false)
  isDemo               Boolean   @default(false)
  defaultLocale        String    @default("ro")
  weekStart            String    @default("MONDAY")
  isActive             Boolean   @default(true)
  createdByAgentId     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users              User[]
  members            OrganizationMember[]
  teamInvitations    TeamInvitation[]
  suppliers          Supplier[]
  maintenanceTasks   MaintenanceTask[]
  maintenanceEvents  MaintenanceEvent[]
  expenses           Expense[]
  notifications      Notification[]
  notificationJobs   NotificationJob[]
  notificationPreferences NotificationPreference[]
  telegramIntegration TelegramIntegration?
  emailIntegration    EmailIntegration?
  smsIntegration      SMSIntegration?
  settings           OrganizationSetting?
  properties         Property[]
  propertyGroups     PropertyGroup[]
  clients            Client[]
  reservations       Reservation[]
  cleanings          Cleaning[]
  subscription       Subscription?
  usageMeters        UsageMeter[]
  propertyChannels   PropertyChannel[]
  syncConflicts      SyncConflict[]
  invoices           Invoice[]
  auditLogs          AuditLog[]
  feedbacks          Feedback[]
  featureRequests    FeatureRequest[]
  clientNotes        ClientNote[]
  leads              Lead[]
  chatMessages       AssociationChatMessage[]
  invitations        Invitation[]
  condoBuildings     CondoBuilding[]
  condoUnits         CondoUnit[]
  annualSummaries    AnnualSummary[]
  announcements      CondoAnnouncement[]
  buildings          Building[]
  staircases         Staircase[]
  apartments         Apartment[]
  residentProfiles   ResidentProfile[]
  payments           Payment[]
  issues             Issue[]
  publicAnnouncements Announcement[]
  announcementComments AnnouncementComment[]
  documents          Document[]
  voteSessions       VoteSession[]
  votes              Vote[]
  importJobs         ImportJob[]
  importedPaymentBatches ImportedPaymentBatch[]
  importedPayments      ImportedPayment[]
  paymentMatches        PaymentMatch[]
  importMappingTemplates ImportMappingTemplate[]
  initialBalances    InitialBalance[]
  monthlyCharges     MonthlyCharge[]
  residentInvoices   ResidentInvoice[]
  receipts           Receipt[]
  paymentReminders   PaymentReminder[]
  reminderRules      ReminderRule[]
  apartmentReminderSettings ApartmentReminderSettings[]
  reminderLogs       ReminderLog[]
  onboardingChecklist OnboardingChecklist?
  supportSessions      SupportSession[]
  paymentIntents     PaymentIntent[]
  paymentProviderConfigs PaymentProviderConfig[]
  subscriptionContracts OrganizationSubscription[]
  billingInvoices      OrganizationInvoice[]
  billingPayments      OrganizationPayment[]
  limits             OrganizationLimits?
  privacySettings    PrivacySettings?
  fileAssets         FileAsset[]
  chatConversations  ChatConversation[]
  supportChatMessages ChatMessage[]
  pushSubscriptions  PushSubscription[]
  systemErrorLogs    SystemErrorLog[]
  createdByAgent     User?       @relation("CreatedByAgent", fields: [createdByAgentId], references: [id], onDelete: SetNull)
  ownerAdmin        User?        @relation("OrganizationOwnerAdmin", fields: [ownerAdminId], references: [id], onDelete: SetNull)

  @@index([createdByAgentId])
  @@index([ownerAdminId])
  @@map("organizations")
}

model PrivacySettings {
  id                               String   @id @default(uuid())
  organizationId                   String   @unique
  showResidentNamesInCommunity     Boolean  @default(false)
  showApartmentNumbersInCommunity  Boolean  @default(false)
  allowResidentsToContactEachOther Boolean  @default(false)
  showIssueReporterName            Boolean  @default(false)
  showVoteParticipants             Boolean  @default(false)
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("privacy_settings")
}

model OrganizationLimits {
  id             String   @id @default(uuid())
  organizationId String   @unique
  maxApartments  Int?
  maxBuildings   Int?
  maxTeamMembers Int?
  maxResidents   Int?
  maxStorageMb   Int?
  modulesJson    Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("organization_limits")
}

model FileAsset {
  id               String              @id @default(uuid())
  organizationId   String?
  uploadedByUserId String
  entityType       FileAssetEntityType
  entityId         String?
  fileName         String
  fileUrl          String
  mimeType         String
  sizeBytes        Int
  storageProvider  FileStorageProvider @default(LOCAL)
  createdAt        DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  uploadedBy   User          @relation("FileAssetUploadedByUser", fields: [uploadedByUserId], references: [id], onDelete: Cascade)
  chatMessages ChatMessage[]

  @@index([organizationId, entityType])
  @@index([entityId])
  @@index([uploadedByUserId])
  @@map("file_assets")
}

model OnboardingChecklist {
  id                        String   @id @default(uuid())
  organizationId            String   @unique
  buildingsCreated          Boolean  @default(false)
  apartmentsImported        Boolean  @default(false)
  residentsImported         Boolean  @default(false)
  tariffsConfigured         Boolean  @default(false)
  paymentProviderConfigured Boolean  @default(false)
  firstInvoicesGenerated    Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("onboarding_checklists")
}

model Feedback {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String
  userRole       String
  pageUrl        String?
  type           FeedbackType
  title          String
  message        String
  status         FeedbackStatus   @default(NEW)
  priority       FeedbackPriority @default(MEDIUM)
  screenshotUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@map("feedback")
}

model FeatureRequest {
  id              String                   @id @default(uuid())
  organizationId  String?
  createdByUserId String
  title           String
  description     String
  category        FeatureRequestCategory
  status          FeatureRequestStatus     @default(NEW)
  visibility      FeatureRequestVisibility @default(INTERNAL)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("FeatureRequestCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Cascade)
  votes        FeatureVote[]

  @@index([status, category, visibility])
  @@index([organizationId, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("feature_requests")
}

model FeatureVote {
  id               String   @id @default(uuid())
  featureRequestId String
  userId           String
  createdAt        DateTime @default(now())

  featureRequest FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, userId])
  @@index([userId, createdAt])
  @@map("feature_votes")
}

model ReleaseNote {
  id         String                @id @default(uuid())
  title      String
  content    String
  version    String?
  targetRole ReleaseNoteTargetRole @default(ALL)
  isPublished Boolean              @default(false)
  publishedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  releaseReads ReleaseNoteRead[]

  @@index([isPublished, targetRole, createdAt])
  @@map("release_notes")
}

model ReleaseNoteRead {
  id            String   @id @default(uuid())
  releaseNoteId String
  userId        String
  readAt        DateTime @default(now())

  releaseNote ReleaseNote @relation(fields: [releaseNoteId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([releaseNoteId, userId])
  @@index([userId, readAt])
  @@map("release_note_reads")
}

model EmailTemplate {
  id         String                  @id @default(uuid())
  key        String
  name       String
  subject    String
  body       String
  targetRole EmailTemplateTargetRole @default(ALL)
  isDefault  Boolean                 @default(false)
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt

  @@index([key, targetRole])
  @@map("email_templates")
}

model Lead {
  id               String     @id @default(uuid())
  name             String
  phone            String
  email            String
  associationName  String?
  apartmentsCount  Int?
  city             String?
  source           LeadSource @default(WEBSITE)
  notes            String?
  status           LeadStatus @default(NEW)
  organizationId   String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  activities   LeadActivity[]
  demoRequests DemoRequest[]

  @@index([status, createdAt])
  @@index([organizationId, createdAt])
  @@index([source, createdAt])
  @@index([city, createdAt])
  @@map("leads")
}

model DemoRequest {
  id              String            @id @default(uuid())
  leadId          String?
  name            String
  phone           String
  email           String
  associationName String?
  apartmentsCount Int?
  preferredDate   String?
  preferredTime   String?
  message         String?
  status          DemoRequestStatus @default(NEW)
  scheduledAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([leadId, createdAt])
  @@index([email, createdAt])
  @@map("demo_requests")
}

model ClientNote {
  id              String         @id @default(uuid())
  organizationId  String
  createdByUserId String
  type            ClientNoteType @default(OTHER)
  title           String
  content         String
  followUpAt      DateTime?
  followUpDone    Boolean        @default(false)
  followUpDoneAt  DateTime?
  followUpReminderSentAt DateTime?
  isImportant     Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser User         @relation("ClientNoteCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([type, createdAt])
  @@index([followUpAt])
  @@index([followUpDone, followUpAt])
  @@map("client_notes")
}

model SuperAdminTask {
  id               String                    @id @default(uuid())
  title            String
  description      String?
  status           SuperAdminTaskStatus      @default(TODO)
  priority         SuperAdminTaskPriority    @default(MEDIUM)
  relatedType      SuperAdminTaskRelatedType?
  relatedId        String?
  dueDate          DateTime?
  createdByUserId  String
  assignedToUserId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  createdByUser User  @relation("SuperAdminTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  assignedToUser User? @relation("SuperAdminTaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([dueDate])
  @@index([createdByUserId, createdAt])
  @@index([assignedToUserId, createdAt])
  @@map("superadmin_tasks")
}

model QACheck {
  id           String        @id @default(uuid())
  key          String        @unique
  section      String
  title        String
  status       QACheckStatus @default(NOT_TESTED)
  notes        String?
  lastTestedAt DateTime?
  testedByUserId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  testedByUser User? @relation("QACheckTestedBy", fields: [testedByUserId], references: [id], onDelete: SetNull)

  @@index([section, status])
  @@index([lastTestedAt])
  @@index([testedByUserId, updatedAt])
  @@map("qa_checks")
}

model BetaReadinessCheck {
  id             String              @id @default(uuid())
  key            String              @unique
  title          String
  status         BetaReadinessStatus @default(NOT_CHECKED)
  notes          String?
  isCritical     Boolean             @default(true)
  lastCheckedAt  DateTime?
  checkedByUserId String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  checkedByUser User? @relation("BetaReadinessCheckedBy", fields: [checkedByUserId], references: [id], onDelete: SetNull)

  @@index([status, isCritical])
  @@index([lastCheckedAt])
  @@map("beta_readiness_checks")
}

model BetaLaunchConfig {
  id             String           @id @default("default")
  launchStatus   BetaLaunchStatus @default(NOT_READY)
  maintenanceMode Boolean         @default(false)
  updatedByUserId String?
  updatedAt      DateTime         @updatedAt
  createdAt      DateTime         @default(now())

  updatedByUser User? @relation("BetaLaunchUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("beta_launch_config")
}

model LeadActivity {
  id              String           @id @default(uuid())
  leadId          String
  type            LeadActivityType
  content         String
  createdByUserId String
  createdAt       DateTime         @default(now())

  lead          Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdByUser User @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([createdByUserId, createdAt])
  @@map("lead_activities")
}

model HelpArticle {
  id          String         @id @default(uuid())
  title       String
  slug        String         @unique
  content     String
  targetRole  HelpTargetRole @default(ALL)
  category    HelpCategory   @default(OTHER)
  isPublished Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([targetRole, isPublished, createdAt])
  @@index([category, isPublished, createdAt])
  @@map("help_articles")
}

model AssociationChatMessage {
  id             String   @id @default(uuid())
  organizationId String
  senderId       String
  text           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([senderId, createdAt])
  @@map("association_chat_messages")
}

model Invitation {
  id              String           @id @default(cuid())
  organizationId  String
  email           String
  phone           String?
  role            Role             @default(RESIDENT)
  apartmentId     String?
  residentType    ResidentType?
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime
  invitedByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("UserInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)
