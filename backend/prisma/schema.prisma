  updatedAt      DateTime             @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  batch        ImportedPaymentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedPayment Payment?           @relation(fields: [matchedPaymentId], references: [id], onDelete: SetNull)
  matches      PaymentMatch[]

  @@index([organizationId, status])
  @@index([batchId])
  @@index([invoiceNumber])
  @@index([apartmentNumber])
  @@index([paymentDate])
  @@map("imported_payments")
}

model PaymentMatch {
  id               String            @id @default(uuid())
  organizationId   String
  importedPaymentId String
  invoiceId        String?
  apartmentId      String?
  confidenceScore  Int
  status           PaymentMatchStatus
  reason           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedPayment ImportedPayment @relation(fields: [importedPaymentId], references: [id], onDelete: Cascade)
  invoice        ResidentInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  apartment      Apartment?       @relation(fields: [apartmentId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([importedPaymentId])
  @@index([invoiceId])
  @@index([apartmentId])
  @@map("payment_matches")
}

model ImportMappingTemplate {
  id             String                @id @default(uuid())
  organizationId String
  source         ImportedPaymentSource
  name           String
  mappingJson    Json
  isDefault      Boolean               @default(false)
  createdByUserId String
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ImportMappingTemplateCreatedByUser", fields: [createdByUserId], references: [id], onDelete: Restrict)
  batches      ImportedPaymentBatch[]

  @@index([organizationId, source])
  @@index([createdByUserId])
  @@map("import_mapping_templates")
}
