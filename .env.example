# Production-oriented Docker Compose template for Espace SaaS.
# Copy to `.env.production.local` or `.env.staging.local` and fill secrets manually.

# Branding / environment
APP_NAME="Espace SaaS"
APP_ENV=production
APP_DEBUG=false
NODE_ENV=production

# Domain / canonical URL
DOMAIN=www.espace.md
APP_URL=https://www.espace.md
CANONICAL_URL=https://www.espace.md
FRONTEND_URL=https://www.espace.md
API_URL=https://www.espace.md/api
CORS_ORIGIN=https://www.espace.md,https://espace.md
CORS_ALLOW_VERCEL_PREVIEWS=false
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.espace.md
TRUST_PROXY=true

# Database (PostgreSQL)
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql://espace:replace_me@postgres:5432/espace_db?schema=public
DIRECT_URL=postgresql://espace:replace_me@postgres:5432/espace_db?schema=public

# Auth / session / logging
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
LOG_HTTP=false
APP_VERSION=0.1.0-beta

# Files / storage
FILE_STORAGE_PROVIDER=LOCAL

# Email / notifications
NOTIFICATIONS_EXTERNAL_ENABLED=true
NOTIFICATIONS_DEV_MODE=false
EMAIL_PROVIDER=RESEND
EMAIL_FROM_NAME=Espace SaaS
EMAIL_FROM_ADDRESS=no-reply@espace.md
EMAIL_REPLY_TO=support@espace.md
EMAIL_FROM=Espace SaaS <no-reply@espace.md>
SUPPORT_EMAIL=support@espace.md
RESEND_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAIL_ENABLED=false
MAIL_FROM=Espace SaaS <no-reply@espace.md>
EMAIL_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_PASS=
SMS_PROVIDER=CONSOLE
SMS_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CUSTOM_SMS_ENDPOINT=
CUSTOM_SMS_API_KEY=

# Optional auth features
ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://www.espace.md/api/auth/google/callback
ENABLE_DEMO_LOGIN=false
ALLOW_LEGACY_ADMIN_PERMISSION_FALLBACK=false
ENABLE_CHANNELS_UI=false

# Payments (current runtime supports MANUAL_TEST/BPAY scaffolding only)
PAYMENTS_EXTERNAL_ENABLED=false
PAYMENTS_TEST_MODE=true
PAYMENTS_MANUAL_TEST_WEBHOOK_SECRET=
BPAY_ENABLED=false
BPAY_MERCHANT_ID=
BPAY_API_KEY=
BPAY_SECRET=

# Reserved placeholders for future live provider rollout. Leave empty until implemented end-to-end.
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=

# Optional bootstrap / seed controls
SEED=false
SEED_DEMO=false
SEED_SUPERADMIN_PASSWORD=
PRODUCTION_SUPERADMIN_EMAIL=
PRODUCTION_SUPERADMIN_PASSWORD=
PRODUCTION_SUPERADMIN_FIRST_NAME=Platform
PRODUCTION_SUPERADMIN_LAST_NAME=Admin
PRODUCTION_SUPERADMIN_PHONE=
PRODUCTION_SUPERADMIN_ORGANIZATION_ID=

# Web push / PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Frontend public env
NEXT_PUBLIC_APP_URL=https://www.espace.md
NEXT_PUBLIC_API_URL=https://www.espace.md/api
NEXT_PUBLIC_SOCKET_URL=https://www.espace.md
NEXT_PUBLIC_DEFAULT_LOCALE=ro
NEXT_PUBLIC_ENABLE_BILLING_UI=false
NEXT_PUBLIC_ENABLE_SOFT_LIMITS=false
NEXT_PUBLIC_ENABLE_CHANNELS_UI=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_DEMO_LOGIN=false
NEXT_PUBLIC_ENABLE_DEMO=false
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_REQUIRE_BETA_ACCESS=false
NEXT_PUBLIC_SHOW_DEV_RESET_LINK=false
NEXT_PUBLIC_DEBUG_API=false
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_APP_VERSION=0.1.0-beta
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
