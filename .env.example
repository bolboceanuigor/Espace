# Supabase PostgreSQL.
# DATABASE_URL uses Supabase Transaction Pooler/PgBouncer.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# DIRECT_URL uses Supabase direct PostgreSQL connection for approved Prisma migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Backend production runtime.
NODE_ENV="production"
PORT=10000
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="https://espace.md"
APP_URL="https://espace.md"
API_URL="https://espace-ru41.onrender.com"
CORS_ORIGIN="https://espace.md,https://www.espace.md"
CORS_ALLOW_VERCEL_PREVIEWS="false"

# Public production URLs.
NEXT_PUBLIC_APP_URL="https://espace.md"
NEXT_PUBLIC_API_URL="https://espace-ru41.onrender.com"
NEXT_PUBLIC_ENABLE_DEMO_LOGIN="false"

# Optional email delivery. Leave empty until configured in Render.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM="Espace <no-reply@espace.md>"

# Optional production superadmin bootstrap script.
# Do not commit real values.
PRODUCTION_SUPERADMIN_EMAIL=""
PRODUCTION_SUPERADMIN_PASSWORD=""

# Optional future frontend Supabase client placeholders.
# These are public anon values only. Never put service_role in frontend env.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
