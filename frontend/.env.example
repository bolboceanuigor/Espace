# Public frontend URL used for metadata, canonical links and redirects.
NEXT_PUBLIC_APP_URL="https://espace.md"

# Public backend API URL. The frontend normalizes either form:
# - https://api.espace.md
# - https://api.espace.md/api
NEXT_PUBLIC_API_URL="https://api.espace.md"

# Optional future Supabase browser client placeholders.
# Public anon key only; never expose service_role in frontend env.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Optional socket URL. Leave empty to derive from NEXT_PUBLIC_API_URL when supported by the page.
NEXT_PUBLIC_SOCKET_URL=

NEXT_PUBLIC_DEFAULT_LOCALE=ro
NEXT_PUBLIC_ENABLE_BILLING_UI=false
NEXT_PUBLIC_ENABLE_SOFT_LIMITS=false
NEXT_PUBLIC_ENABLE_CHANNELS_UI=false
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_APP_VERSION=0.1.0-beta
